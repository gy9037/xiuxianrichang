.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 64rpx;
}

.login-title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #8b5cf6, #f59e0b);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 80rpx;
}

.login-form {
  width: 100%;
}

.login-form .form-group {
  margin-bottom: 32rpx;
}

.input-wrap {
  background: #252540;
  border: 1rpx solid #334155;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.input-wrap input {
  font-size: 30rpx;
  color: #e2e8f0;
  width: 100%;
}

.input-placeholder {
  color: #94a3b8;
  font-size: 30rpx;
}

.login-form .btn {
  width: 100%;
  margin-top: 16rpx;
}

.login-version {
  position: fixed;
  bottom: 64rpx;
  font-size: 20rpx;
}

.wx-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.switch-link {
  text-align: center;
  font-size: 24rpx;
  color: #8b5cf6;
  margin-top: 32rpx;
  padding: 16rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #252540;
  border: 1rpx solid #334155;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user-card:active {
  opacity: 0.7;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
