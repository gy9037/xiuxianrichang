<view class="page-container">

  <!-- 顶部：主 Tab + 炼化规则 -->
  <view class="flex-between" style="margin-bottom: 32rpx;">
    <view class="tab-bar" style="flex: 1; margin-bottom: 0; margin-right: 24rpx;">
      <view class="tab-bar-item {{activeSection === 'items' ? 'active' : ''}}"
            data-section="items" bindtap="onSwitchSection">道具</view>
      <view class="tab-bar-item {{activeSection === 'rewards' ? 'active' : ''}}"
            data-section="rewards" bindtap="onSwitchSection">奖励</view>
    </view>
    <view class="rules-link" bindtap="onShowRules">炼化规则</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-state">加载中...</view>

  <!-- ========== 道具 Section ========== -->
  <block wx:elif="{{activeSection === 'items'}}">

    <!-- 空状态 -->
    <view wx:if="{{items.length === 0}}" class="empty-state">
      <view style="margin-bottom: 24rpx;">背包空空如也</view>
      <button class="btn btn-primary btn-small" bindtap="onGoReport">去上报行为</button>
    </view>

    <block wx:else>
      <!-- 属性分类 Tab -->
      <scroll-view scroll-x class="attr-tabs">
        <view class="attr-tab-inner">
          <view wx:for="{{attrTabs}}" wx:key="key"
                class="attr-tab {{activeAttr === item.key ? 'attr-tab-active' : ''}}"
                data-key="{{item.key}}" bindtap="onSwitchAttr">
            {{item.name}}({{item.count}})
          </view>
        </view>
      </scroll-view>

      <!-- 全选按钮 -->
      <view class="flex-between" style="margin-bottom: 16rpx;">
        <view class="text-dim" style="font-size: 24rpx;">
          当前分类 {{displayItems.length}} 件
        </view>
        <view class="select-all-btn" bindtap="onToggleAll">
          {{allChecked ? '取消全选' : '全选'}}
        </view>
      </view>

      <!-- 道具列表 -->
      <view wx:for="{{displayItems}}" wx:key="id"
            class="item-row {{item.checked ? 'item-row-checked' : ''}}"
            data-index="{{index}}" bindtap="onToggleItem">
        <view class="item-checkbox">
          <view class="checkbox-box {{item.checked ? 'checkbox-checked' : ''}}">
            <view wx:if="{{item.checked}}" class="checkbox-tick">✓</view>
          </view>
        </view>
        <view class="item-info">
          <view class="item-name-row">
            <text class="{{item.qualityClass}}">{{item.name}}</text>
            <text class="item-quality-tag {{item.qualityClass}}">{{item.quality}}</text>
          </view>
          <view class="text-dim" style="font-size: 24rpx;">
            临时属性 +{{item.temp_value}}
          </view>
        </view>
      </view>

      <!-- 合成摘要栏 -->
      <view wx:if="{{selectedCount > 0}}" class="synth-bar">
        <view class="synth-info">
          <view class="text-bright" style="font-size: 28rpx;">
            已选 {{selectedCount}} 件 · 总值 {{selectedTotal}}
          </view>
          <view wx:if="{{canSynth}}" class="text-green" style="font-size: 24rpx;">
            可合成 +{{synthGain}} 永久属性
          </view>
          <view wx:else class="text-dim" style="font-size: 24rpx;">
            不足{{10}}点无法合成
          </view>
          <view wx:if="{{canSynth && synthWaste > 0}}" class="text-gold" style="font-size: 24rpx;">
            将浪费 {{synthWaste}} 点
          </view>
        </view>
        <button class="btn btn-primary btn-small synth-btn"
                disabled="{{!canSynth || synthesizing}}"
                bindtap="onSynthesize">
          {{synthesizing ? '合成中...' : '合成'}}
        </button>
      </view>
    </block>
  </block>

  <!-- ========== 奖励 Section ========== -->
  <block wx:elif="{{activeSection === 'rewards'}}">

    <!-- 待兑现 -->
    <view wx:if="{{pendingRewards.length > 0}}">
      <view class="card-title">待兑现</view>
      <view wx:for="{{pendingRewards}}" wx:key="id" class="card card-tight">
        <view class="flex-between" style="margin-bottom: 8rpx;">
          <text class="text-bright" style="font-weight: 600;">{{item.name}}</text>
          <view class="flex-row" style="gap: 12rpx;">
            <text class="tag">{{item.type}}</text>
            <text class="tag">{{item.difficulty}}</text>
          </view>
        </view>
        <view class="text-dim" style="font-size: 24rpx; margin-bottom: 4rpx;">
          发起人：{{item.creator_name}}
        </view>
        <view class="text-gold" style="font-size: 26rpx; margin-bottom: 16rpx;">
          {{item.reward_description}}
        </view>
        <button class="btn btn-primary btn-small"
                disabled="{{redeemingId === item.id}}"
                data-id="{{item.id}}" data-name="{{item.name}}"
                bindtap="onRedeemReward">
          {{redeemingId === item.id ? '兑现中...' : '兑现'}}
        </button>
      </view>
    </view>

    <!-- 已兑现 -->
    <view wx:if="{{redeemedRewards.length > 0}}" style="margin-top: 32rpx;">
      <view class="card-title" style="color: #94a3b8;">已兑现</view>
      <view wx:for="{{redeemedRewards}}" wx:key="id" class="card card-tight" style="opacity: 0.7;">
        <view class="text-bright" style="font-weight: 600; margin-bottom: 4rpx;">{{item.name}}</view>
        <view class="text-gold" style="font-size: 26rpx; margin-bottom: 4rpx;">{{item.reward_description}}</view>
        <view class="text-dim" style="font-size: 22rpx;">兑现于 {{item.redeemed_at}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{pendingRewards.length === 0 && redeemedRewards.length === 0}}" class="empty-state">
      暂无奖励
    </view>
  </block>

  <!-- ========== 炼化规则弹窗 ========== -->
  <view wx:if="{{showRules}}" class="rules-overlay" bindtap="onCloseRules">
    <view class="rules-modal" catchtap="">
      <view class="rules-title">炼化规则</view>
      <view class="rules-body">
        <view class="rules-item">1. 完成行为获得道具，道具有临时属性值</view>
        <view class="rules-item">2. 同属性道具可以合成，每 10 点临时属性转化为 +1 永久属性</view>
        <view class="rules-item">3. 合成时不足 10 点的余数将被浪费，请凑整后再合成</view>
        <view class="rules-item">4. 道具品质：
          <text class="quality-ji">极品</text> >
          <text class="quality-shang">上品</text> >
          <text class="quality-liang">良品</text> >
          <text class="quality-fan">凡品</text>
        </view>
        <view class="rules-item">5. 合成后道具消失，永久属性不可逆</view>
      </view>
      <button class="btn btn-primary" style="margin-top: 32rpx;" bindtap="onCloseRules">知道了</button>
    </view>
  </view>

</view>
