/* 愿望页样式 */

/* 筛选面板 */
.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #252540;
  color: #94a3b8;
  border: 1rpx solid #334155;
  min-height: 56rpx;
}

.filter-chip:active {
  opacity: 0.7;
}

.filter-chip-active {
  background: #8b5cf6;
  color: #fff;
  border-color: #8b5cf6;
}

/* 进度条 */
.progress-bar-bg {
  height: 12rpx;
  background: #252540;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 道具选择行 */
.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  margin-bottom: 8rpx;
  background: #252540;
  border-radius: 16rpx;
  border: 1rpx solid #334155;
}

.item-row:active {
  opacity: 0.8;
}

.item-row-selected {
  border-color: #8b5cf6;
  background: #1e1b4b;
}

.item-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #334155;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  flex-shrink: 0;
}

.item-checkbox-checked {
  background: #8b5cf6;
  border-color: #8b5cf6;
  color: #fff;
}

/* 战斗回合 */
.round-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1e1b4b;
}

.round-item:last-child {
  border-bottom: none;
}

/* 结果横幅 */
.result-banner {
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  font-weight: 700;
}

.result-win {
  background: linear-gradient(135deg, #065f46, #064e3b);
  border: 1rpx solid #10b981;
}

.result-lose {
  background: linear-gradient(135deg, #7f1d1d, #991b1b);
  border: 1rpx solid #ef4444;
}

/* 详情行 */
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

/* 胜利仪式卡片 */
.victory-card {
  background: linear-gradient(135deg, #1a1a2e, #2d1b69);
  border: 1rpx solid #8b5cf6;
}

/* 回合淡入动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
