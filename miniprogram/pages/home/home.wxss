/* 首页样式 */

/* 雷达图卡片 */
.radar-card {
  padding: 8rpx 0;
}

/* Hero 区域 */
.hero-row2 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.hero-cultivation {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hero-row3 {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.hero-help-btn {
  font-size: 24rpx;
  color: #94a3b8;
  padding: 4rpx 12rpx;
  min-width: 48rpx;
  min-height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.env-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.trend-bar {
  width: 100%;
  display: flex;
  flex-direction: column-reverse;
  margin-top: 4rpx;
}

.trend-bar-today {
  box-shadow: 0 0 12rpx rgba(139, 92, 246, 0.4);
}

.trend-day {
  font-size: 22rpx;
  margin-top: 8rpx;
  font-weight: 400;
  color: #94a3b8;
}

.trend-day-today {
  font-size: 22rpx;
  margin-top: 8rpx;
  font-weight: 700;
  color: #8b5cf6;
}

.recommend-item {
  padding: 16rpx 0;
}

.recommend-item-border {
  border-top: 1rpx solid #334155;
}

.recommend-action {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
  min-height: 72rpx;
}

.recommend-action:active {
  opacity: 0.7;
}

.recommend-action-border {
  border-top: 1rpx solid #334155;
}

.achievement-item {
  padding: 12rpx 0;
}

.achievement-item-border {
  border-top: 1rpx solid #334155;
}
