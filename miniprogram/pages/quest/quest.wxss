.quest-daily-card {
  border: 2rpx solid #d4a574;
  margin-bottom: 24rpx;
}

.quest-daily-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #0f0f1a;
  background: linear-gradient(135deg, #d4a574, #f5d4a0);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.quest-card {
  margin-bottom: 16rpx;
}

.quest-type-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.quest-role-tag {
  font-size: 22rpx;
  font-weight: 600;
}

.quest-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #8b5cf6;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.4);
}

.quest-fab:active {
  background: #7c3aed;
}

.fold-action {
  text-align: center;
  padding: 16rpx 0;
  margin-top: 12rpx;
  font-size: 26rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
